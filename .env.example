# Servidor
PORT=8090
# URL pública deste serviço (usada para registrar o webhook na Evolution).
PUBLIC_URL=http://localhost:8090

# Banco (Postgres). O wpp-ai tem o PRÓPRIO banco, separado dos sistemas que o usam.
DATABASE_URL=postgresql://wppai:wppai@localhost:5432/wppai?schema=public

# Evolution API (instância auto-hospedada).
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# Segredo que protege os webhooks recebidos da Evolution (header apikey).
EVOLUTION_WEBHOOK_TOKEN=

# Chave de administração para registrar novos sistemas (POST /admin/systems).
ADMIN_API_KEY=change-me
