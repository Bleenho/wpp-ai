# Copie para deploy/.env e preencha. Gere segredos com: openssl rand -hex 32

# Domínio público do wpp-ai (o Agendota e o painel admin batem aqui). DNS -> IP do VPS.
WPPAI_DOMAIN=wa.seudominio.com

# Chave global da Evolution (interna). = EVOLUTION_API_KEY do wpp-ai.
EVOLUTION_API_KEY=

# (Opcional) valida os webhooks que a Evolution manda ao wpp-ai.
EVOLUTION_WEBHOOK_TOKEN=

# Chave de ADMIN do wpp-ai (para POST /admin/systems). Só sua.
WPPAI_ADMIN_API_KEY=

# Senhas dos bancos.
WPPAI_DB_PASSWORD=
EVOLUTION_DB_PASSWORD=
